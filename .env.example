# Security
# ENCRYPTION_KEY must be 32 bytes hex (64 hex chars)
# generate: python -c "import os; print(os.urandom(32).hex())"
ENCRYPTION_KEY=

# Random string for hash salting
# generate: python -c "import os; print(os.urandom(16).hex())"
HASH_PEPPER=

