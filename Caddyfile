sekbot.duckdns.org {
    encode zstd gzip

    @root path /
    redir @root /dashboard?v=20260415-worker-home 302

    @dashboardShell path / /dashboard
    header @dashboardShell Cache-Control "no-store, no-cache, max-age=0, must-revalidate, private"
    header @dashboardShell Pragma "no-cache"
    header @dashboardShell Expires "0"

    @dashboardHead {
        method HEAD
        path /dashboard
    }
    respond @dashboardHead 200

    reverse_proxy api:8000
}
